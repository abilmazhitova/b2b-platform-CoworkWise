# Скопируйте в .env рядом с docker-compose.yml.
#
# Полный стек (docker-compose.yml): DB_HOST=postgres
# Своя БД на компьютере (docker-compose.host-db.yml): DB_HOST=host.docker.internal

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=coworkwise_db

# JWT (опционально)
# SECRET_KEY=ваш-длинный-секрет-минимум-32-символа
