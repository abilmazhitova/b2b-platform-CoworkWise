# Copy to .env and fill in your values
# Database (PostgreSQL)
# Локальный запуск: 127.0.0.1. В Docker Compose для backend задаётся DB_HOST=postgres (см. корневой docker-compose.yml).
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=coworkwise_db

# JWT
SECRET_KEY=your-secret-key-min-32-chars
ALGORITHM=HS256
